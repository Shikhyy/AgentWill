        </div>

        <h1 className="text-5xl md:text-7xl lg:text-8xl font-black mb-6 leading-[1.05] animate-slide-up">
          On-Chain Rules
          <br />
          <span className="gradient-text">for AI Agents</span>
        </h1>

        <p className="text-lg md:text-xl text-slate-400 max-w-3xl mx-auto mb-10 leading-relaxed animate-slide-up" style={{ animationDelay: '150ms' }}>
          Define exactly what your AI agent can spend, who it can interact with, and what it can reveal.
          Every action verifiable on Base. You stay in control.
        </p>

        <div className="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style={{ animationDelay: '300ms' }}>
          <a href="#demo" className="btn-primary text-lg group flex items-center gap-2">
            <span>Launch Dashboard</span>
            <ArrowRightIcon className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </a>
          <a href="https://github.com/Shikhyy/AgentWill" target="_blank" rel="noopener noreferrer" className="btn-secondary text-lg flex items-center gap-2">
            <GithubIcon className="w-5 h-5" />
            <span>View on GitHub</span>
          </a>
        </div>

        <div className="flex flex-wrap items-center justify-center gap-8 mt-16 animate-slide-up" style={{ animationDelay: '450ms' }}>
          {[
            { icon: <BaseIcon className="w-5 h-5" />, label: 'Built on Base' },
            { icon: <CodeIcon className="w-5 h-5" />, label: 'Solidity 0.8.24' },
            { icon: <ShieldIcon className="w-5 h-5" />, label: 'ERC-8004 Compatible' },
